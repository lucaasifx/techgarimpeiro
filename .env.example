# =============================================================
# TechGarimpeiro — Environment Variables
# Copy to .env and fill in the values
# NEVER commit .env to version control
# =============================================================

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJ...
# SERVICE_ROLE_KEY — use only in backend workers, never in frontend
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=12345:ABCDefgh...
TELEGRAM_WEBHOOK_SECRET=change-me-32-chars-random-string-here
TELEGRAM_MAIN_CHANNEL_ID=-1001234567890
TELEGRAM_DISCUSSION_GROUP_ID=-1009876543210

# ── AliExpress Open Platform ──────────────────────────────────
ALIEXPRESS_APP_KEY=12345678
ALIEXPRESS_APP_SECRET=abcdef1234567890abcdef1234567890
ALIEXPRESS_TRACKING_ID=techgarimpeiro_default

# ── Internal Auth (between admin-panel → workers) ─────────────
CRON_SECRET=change-me-random-secret
INTERNAL_API_SECRET=change-me-internal-secret

# ── Workers ───────────────────────────────────────────────────
# URL base dos workers (usado pelo pg_cron para chamar endpoints HTTP)
WORKERS_BASE_URL=http://localhost:8080
PORT=8080
NODE_ENV=development
LOG_LEVEL=debug

# ── Playwright (worker-enricher only) ─────────────────────────
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
SCRAPER_SESSION_BUCKET=scraper-sessions
SCRAPER_MAX_CONCURRENCY=2
SCRAPER_TIMEOUT_MS=30000

# ── Observabilidade ────────────────────────────────────────────
SENTRY_DSN=https://XXXXXXXX@XXXX.ingest.sentry.io/XXXXXXXX

# ── Admin Panel (Next.js — NEXT_PUBLIC_ são expostos ao browser) ──
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
BOT_INTERNAL_API_URL=http://localhost:8080
